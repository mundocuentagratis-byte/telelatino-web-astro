---
import { appConfig } from "../data/app";
---

<section class="hero" id="inicio">
  <div class="container hero-grid">
    <div class="hero-content">
      <span class="badge">Disponible para Android</span>

      <h1>
        Canales en vivo, deportes y películas en una sola app.
      </h1>

      <p>
        {appConfig.name} es una app de entretenimiento para Android pensada para
        encontrar rápido lo que más buscas: canales principales, eventos deportivos,
        películas y estrenos, sin contenido excesivo ni complicaciones.
      </p>

      <div class="hero-actions">
        <a href={appConfig.apkUrl} class="btn btn-primary" target="_blank" rel="noopener">
          Descargar APK
        </a>

        <a href={appConfig.whatsappUrl} class="btn btn-secondary" target="_blank" rel="noopener">
          WhatsApp
        </a>

        <a href={appConfig.telegramUrl} class="btn btn-secondary" target="_blank" rel="noopener">
          Telegram
        </a>
      </div>

      <div class="hero-stats" aria-label="Beneficios destacados">
        <div>
          <strong>7 días</strong>
          <span>Prueba gratis</span>
        </div>

        <div>
          <strong>6 USD</strong>
          <span>VIP por 6 meses</span>
        </div>

        <div>
          <strong>Android</strong>
          <span>App móvil</span>
        </div>
      </div>
    </div>

    <div class="hero-preview card">
      <div class="phone-frame">
        <div class="phone-top"></div>

        <div class="app-screen">
          <img src={appConfig.image} alt="Logo de la app TELELATINO" />

          <div class="screen-content">
            <span>{appConfig.name}</span>
            <h2>Entretenimiento fácil desde tu móvil</h2>
            <p>
              Canales en vivo, deportes, películas y estrenos en una experiencia
              simple para Android.
            </p>
          </div>
        </div>
      </div>

      <div class="preview-list">
        <div>
          <span class="dot"></span>
          <p>Canales principales en vivo</p>
        </div>

        <div>
          <span class="dot"></span>
          <p>Eventos deportivos destacados</p>
        </div>

        <div>
          <span class="dot"></span>
          <p>Películas y estrenos fáciles de encontrar</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 96px 0 80px;
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    right: -160px;
    top: 120px;
    width: 420px;
    height: 420px;
    border-radius: 999px;
    background: rgba(255, 138, 0, 0.16);
    filter: blur(80px);
    z-index: -1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 54px;
    align-items: center;
  }

  .hero-content h1 {
    margin: 22px 0 20px;
    max-width: 780px;
    font-size: clamp(2.7rem, 6vw, 5.3rem);
    line-height: 0.96;
    letter-spacing: -0.075em;
  }

  .hero-content p {
    max-width: 660px;
    margin: 0;
    color: var(--color-muted);
    font-size: 1.12rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 34px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    max-width: 660px;
    margin-top: 40px;
  }

  .hero-stats div {
    padding: 18px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-stats strong {
    display: block;
    color: var(--color-primary);
    font-size: 1.45rem;
    line-height: 1;
  }

  .hero-stats span {
    display: block;
    margin-top: 8px;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .hero-preview {
    position: relative;
    padding: 18px;
    border-radius: var(--radius-lg);
    transform: rotate(1deg);
  }

  .phone-frame {
    overflow: hidden;
    border-radius: 32px;
    background: linear-gradient(180deg, #101b2c, #050a12);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 14px;
  }

  .phone-top {
    width: 88px;
    height: 6px;
    margin: 0 auto 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.25);
  }

  .app-screen {
    min-height: 430px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 26px;
    overflow: hidden;
    border-radius: 24px;
    background:
      linear-gradient(to top, rgba(0, 0, 0, 0.92), transparent 55%),
      radial-gradient(circle at 75% 18%, rgba(255, 138, 0, 0.58), transparent 24%),
      linear-gradient(135deg, #10243d, #06111f 65%);
  }

  .app-screen::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, 0.12), transparent 36%),
      radial-gradient(circle at 18% 22%, rgba(0, 212, 255, 0.18), transparent 28%);
  }

  .app-screen img {
    position: relative;
    z-index: 1;
    width: min(78%, 330px);
    margin: 0 auto 28px;
    border-radius: 32px;
    box-shadow: 0 30px 80px rgba(255, 138, 0, 0.22);
  }

  .screen-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .screen-content span {
    color: #ffd8a8;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .screen-content h2 {
    max-width: 380px;
    margin: 10px auto;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .screen-content p {
    max-width: 380px;
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.74);
  }

  .preview-list {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .preview-list div {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
  }

  .preview-list p {
    margin: 0;
    color: var(--color-muted);
    font-weight: 700;
    font-size: 0.93rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--color-success);
    box-shadow: 0 0 0 6px rgba(50, 213, 131, 0.12);
  }

  @media (max-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-preview {
      transform: none;
    }
  }

  @media (max-width: 680px) {
    .hero {
      padding: 70px 0 56px;
    }

    .hero-content h1 {
      letter-spacing: -0.055em;
    }

    .hero-stats {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
    }

    .app-screen {
      min-height: 360px;
      padding: 20px;
    }
  }
</style>