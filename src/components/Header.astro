---
import { appConfig } from "../data/app";
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Ir al inicio de TELELATINO">
      <img src={appConfig.image} alt="Logo TELELATINO" />
      <span>
        <strong>{appConfig.name}</strong>
        <small>Android</small>
      </span>
    </a>

    <nav class="nav-links" aria-label="Navegación principal">
      <a href="/#beneficios">Beneficios</a>
      <a href="/#contenido">Contenido</a>
      <a href="/#planes">Planes</a>
      <a href="/noticias/">Noticias</a>
      <a href="/blog/">Blog</a>
      <a href="/contacto/">Contacto</a>
    </nav>

    <a href={appConfig.apkUrl} class="btn btn-primary header-cta" target="_blank" rel="noopener">
      Descargar APK
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(5, 10, 18, 0.78);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    min-height: 82px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: max-content;
  }

  .brand img {
    width: 46px;
    height: 46px;
    object-fit: cover;
    border-radius: 14px;
    box-shadow: 0 12px 28px rgba(255, 138, 0, 0.2);
  }

  .brand span {
    display: grid;
    line-height: 1;
  }

  .brand strong {
    color: var(--color-text);
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .brand small {
    margin-top: 5px;
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 26px;
    flex: 1;
  }

  .nav-links a {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.95rem;
    font-weight: 800;
  }

  .nav-links a:hover {
    color: var(--color-primary);
  }

  .header-cta {
    min-width: max-content;
  }

  @media (max-width: 980px) {
    .nav-links {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .header-inner {
      min-height: 74px;
    }

    .brand img {
      width: 42px;
      height: 42px;
    }

    .header-cta {
      padding-inline: 16px;
      font-size: 0.85rem;
    }
  }
</style>