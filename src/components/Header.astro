---
import { appConfig } from "../data/app";

const navItems = [
  {
    label: "Beneficios",
    href: "/#beneficios",
  },
  {
    label: "Contenido",
    href: "/#contenido",
  },
  {
    label: "Planes",
    href: "/#planes",
  },
  {
    label: "Noticias",
    href: "/noticias/",
  },
  {
    label: "Películas",
    href: "/blog/",
  },
  {
    label: "Descargar",
    href: "/descargar/",
  },
  {
    label: "Contacto",
    href: "/contacto/",
  },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label="Ir al inicio">
      <img src={appConfig.image} alt="TELELATINO Android" width="46" height="46" />
      <span>
        <strong>{appConfig.name}</strong>
        <small>Android</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>

    <a href="/descargar/" class="download-btn">
      Descargar APK
    </a>
  </div>

  <nav class="mobile-nav" aria-label="Navegación móvil">
    {navItems.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(7, 14, 28, 0.96);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .header-inner {
    width: min(1120px, calc(100% - 32px));
    min-height: 72px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: #ffffff;
    text-decoration: none;
    flex: 0 0 auto;
  }

  .brand img {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    object-fit: cover;
  }

  .brand span {
    display: grid;
    line-height: 1;
  }

  .brand strong {
    font-size: 0.95rem;
    font-weight: 950;
    letter-spacing: -0.03em;
  }

  .brand small {
    margin-top: 4px;
    color: #ffd56d;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    flex: 1;
  }

  .desktop-nav a,
  .mobile-nav a {
    color: rgba(255, 255, 255, 0.84);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 850;
    white-space: nowrap;
  }

  .desktop-nav a:hover,
  .mobile-nav a:hover {
    color: #ffd56d;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 11px 20px;
    border-radius: 999px;
    background: linear-gradient(180deg, #ffe47c 0%, #f1c344 100%);
    color: #171717;
    font-size: 0.86rem;
    font-weight: 950;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 8px 22px rgba(255, 198, 69, 0.22);
  }

  .mobile-nav {
    display: none;
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 0 0 14px;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .mobile-nav::-webkit-scrollbar {
    display: none;
  }

  .mobile-nav a {
    flex: 0 0 auto;
    padding: 9px 13px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.09);
  }

  @media (max-width: 980px) {
    .desktop-nav {
      gap: 14px;
    }

    .desktop-nav a {
      font-size: 0.82rem;
    }
  }

  @media (max-width: 860px) {
    .header-inner {
      min-height: 68px;
    }

    .desktop-nav {
      display: none;
    }

    .mobile-nav {
      display: flex;
    }
  }

  @media (max-width: 520px) {
    .header-inner {
      width: min(100% - 24px, 1120px);
      gap: 12px;
    }

    .mobile-nav {
      width: min(100% - 24px, 1120px);
    }

    .brand img {
      width: 44px;
      height: 44px;
    }

    .brand strong {
      font-size: 0.84rem;
    }

    .download-btn {
      min-height: 40px;
      padding: 10px 15px;
      font-size: 0.78rem;
    }
  }
</style>