---
import { appConfig } from "../data/app";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand">
        <img src={appConfig.image} alt="Logo TELELATINO" />
        <span>
          <strong>{appConfig.name}</strong>
          <small>Entretenimiento para Android</small>
        </span>
      </a>

      <p>
        {appConfig.name} es una app de entretenimiento para Android con canales en vivo,
        eventos deportivos, películas y estrenos. Diseñada para encontrar rápido lo que
        más buscas desde tu móvil.
      </p>

      <div class="footer-actions">
        <a href={appConfig.apkUrl} class="btn btn-primary" target="_blank" rel="noopener">
          Descargar APK
        </a>

        <a href={appConfig.whatsappUrl} class="btn btn-secondary" target="_blank" rel="noopener">
          WhatsApp
        </a>
      </div>
    </div>

    <div class="footer-links">
      <h3>Sitio</h3>
      <a href="/">Inicio</a>
      <a href="/noticias/">Noticias</a>
      <a href="/blog/">Blog</a>
      <a href="/contacto/">Contacto</a>
    </div>

    <div class="footer-links">
      <h3>Secciones</h3>
      <a href="/#beneficios">Beneficios</a>
      <a href="/#contenido">Contenido</a>
      <a href="/#planes">Planes</a>
      <a href="/#descargar">Descargar</a>
    </div>

    <div class="footer-links">
      <h3>Legal</h3>
      <a href="/terminos/">Términos</a>
      <a href="/privacidad/">Privacidad</a>
      <a href="/contacto/">Contacto</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© 2026 {appConfig.name}. Todos los derechos reservados.</p>
    <p>Disponible para Android · {appConfig.trial.text} · {appConfig.vipPlan.text}</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 72px 0 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(3, 7, 13, 0.9);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.7fr 0.7fr 0.7fr;
    gap: 38px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .brand img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 15px;
    box-shadow: 0 12px 28px rgba(255, 138, 0, 0.2);
  }

  .brand span {
    display: grid;
    line-height: 1;
  }

  .brand strong {
    color: var(--color-text);
    font-size: 1rem;
  }

  .brand small {
    margin-top: 5px;
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 800;
  }

  .footer-brand p {
    max-width: 520px;
    margin: 22px 0 0;
    color: var(--color-muted);
  }

  .footer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 26px;
  }

  .footer-links {
    display: grid;
    align-content: start;
    gap: 12px;
  }

  .footer-links h3 {
    margin: 0 0 8px;
    color: var(--color-text);
    font-size: 1rem;
  }

  .footer-links a {
    color: var(--color-muted);
    font-weight: 700;
  }

  .footer-links a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-top: 54px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-bottom p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }

  @media (max-width: 620px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-actions {
      flex-direction: column;
    }
  }
</style>