---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout
  title="TeleLatino Oficial | Entretenimiento, TV y noticias digitales"
  description="Portal promocional e informativo sobre entretenimiento digital, televisión, deportes, guías y novedades para usuarios."
>
  <Hero />

  <section class="section" id="beneficios">
    <div class="container">
      <div class="section-title">
        <span>Beneficios</span>
        <h2>Una web pensada para promocionar, informar y posicionar.</h2>
        <p>
          El objetivo es tener una página rápida, moderna y preparada para aparecer mejor
          en buscadores con contenido útil y bien organizado.
        </p>
      </div>

      <div class="benefits-grid">
        <article class="benefit-card card">
          <div class="icon">⚡</div>
          <h3>Carga rápida</h3>
          <p>
            Construida con Astro para obtener una web liviana, veloz y optimizada para SEO.
          </p>
        </article>

        <article class="benefit-card card">
          <div class="icon">📈</div>
          <h3>SEO escalable</h3>
          <p>
            Estructura lista para blog, noticias, sitemap, RSS y contenido indexable.
          </p>
        </article>

        <article class="benefit-card card">
          <div class="icon">📱</div>
          <h3>Promoción de app</h3>
          <p>
            Página enfocada en explicar la propuesta de valor y dirigir usuarios hacia la app.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section content-section" id="contenido">
    <div class="container content-grid">
      <div>
        <span class="badge">Contenido digital</span>
        <h2>Noticias, guías y novedades para atraer tráfico orgánico.</h2>
        <p>
          La web no será solo una página bonita. También funcionará como un portal de
          contenido para crear artículos, publicar noticias y mejorar el posicionamiento
          en Google de forma ordenada.
        </p>

        <div class="content-list">
          <div>
            <strong>01</strong>
            <span>Noticias deportivas y entretenimiento</span>
          </div>

          <div>
            <strong>02</strong>
            <span>Guías para usuarios nuevos</span>
          </div>

          <div>
            <strong>03</strong>
            <span>Artículos optimizados para buscadores</span>
          </div>
        </div>
      </div>

      <div class="content-card card">
        <h3>Portal preparado para crecer</h3>
        <p>
          Más adelante podremos conectar generación automática de noticias, categorías,
          artículos relacionados y páginas especiales para campañas.
        </p>

        <div class="mini-dashboard">
          <div>
            <span>SEO</span>
            <strong>Activo</strong>
          </div>

          <div>
            <span>Noticias</span>
            <strong>Listas</strong>
          </div>

          <div>
            <span>Blog</span>
            <strong>Escalable</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="planes">
    <div class="container">
      <div class="section-title">
        <span>Planes</span>
        <h2>Una sección clara para explicar la oferta principal.</h2>
        <p>
          Aquí podremos ajustar los textos reales de tu app, beneficios, precio, prueba,
          contacto o botón de descarga cuando lo tengas definido.
        </p>
      </div>

      <div class="pricing-card card">
        <div>
          <span class="badge">Acceso promocional</span>
          <h3>Conoce la experiencia completa</h3>
          <p>
            Espacio listo para presentar tu producto, mostrar beneficios y llevar al usuario
            al canal de descarga o contacto.
          </p>
        </div>

        <a href="#descargar" class="btn btn-primary">Ver información</a>
      </div>
    </div>
  </section>

  <section class="section download-section" id="descargar">
    <div class="container download-box card">
      <span class="badge">TeleLatino Oficial</span>
      <h2>Tu landing quedará lista para promocionar la app y trabajar SEO.</h2>
      <p>
        Este será el punto principal para enviar usuarios desde Google, redes sociales,
        campañas o enlaces directos hacia la información de tu aplicación.
      </p>

      <div class="download-actions">
        <a href="/blog/" class="btn btn-secondary">Leer guías</a>
        <a href="/noticias/" class="btn btn-primary">Ver noticias</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .benefit-card {
    padding: 28px;
  }

  .icon {
    width: 54px;
    height: 54px;
    display: grid;
    place-items: center;
    margin-bottom: 22px;
    border-radius: 18px;
    background: rgba(255, 138, 0, 0.14);
    font-size: 1.6rem;
  }

  .benefit-card h3 {
    margin: 0 0 10px;
    font-size: 1.35rem;
  }

  .benefit-card p {
    margin: 0;
    color: var(--color-muted);
  }

  .content-section {
    background: rgba(255, 255, 255, 0.025);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    gap: 56px;
    align-items: center;
  }

  .content-grid h2 {
    margin: 22px 0 16px;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.055em;
  }

  .content-grid p {
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .content-list {
    display: grid;
    gap: 14px;
    margin-top: 28px;
  }

  .content-list div {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .content-list strong {
    color: var(--color-primary);
  }

  .content-list span {
    color: var(--color-muted);
    font-weight: 700;
  }

  .content-card {
    padding: 34px;
  }

  .content-card h3 {
    margin: 0 0 12px;
    font-size: 1.7rem;
  }

  .mini-dashboard {
    display: grid;
    gap: 14px;
    margin-top: 28px;
  }

  .mini-dashboard div {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 16px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.06);
  }

  .mini-dashboard span {
    color: var(--color-muted);
  }

  .mini-dashboard strong {
    color: var(--color-success);
  }

  .pricing-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding: 34px;
  }

  .pricing-card h3 {
    margin: 18px 0 10px;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    line-height: 1.1;
  }

  .pricing-card p {
    max-width: 680px;
    margin: 0;
    color: var(--color-muted);
  }

  .download-box {
    padding: 54px 34px;
    text-align: center;
  }

  .download-box h2 {
    max-width: 820px;
    margin: 22px auto 16px;
    font-size: clamp(2rem, 4vw, 3.3rem);
    line-height: 1.05;
  }

  .download-box p {
    max-width: 720px;
    margin: 0 auto;
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .download-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 32px;
  }

  @media (max-width: 900px) {
    .benefits-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .download-actions {
      flex-direction: column;
    }
  }
</style>