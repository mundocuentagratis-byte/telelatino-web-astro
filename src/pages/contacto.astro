---
import BaseLayout from "../layouts/BaseLayout.astro";
import { appConfig } from "../data/app";
---

<BaseLayout
  title="Contacto | TELELATINO"
  description="Contacta con TELELATINO por WhatsApp o Telegram para información sobre la app, prueba gratis, descarga APK y plan VIP."
>
  <section class="contact-page">
    <div class="container contact-grid">
      <div class="contact-info">
        <span class="badge">Contacto TELELATINO</span>

        <h1>¿Tienes dudas sobre la app?</h1>

        <p>
          Puedes comunicarte con TELELATINO para recibir información sobre la descarga
          del APK, la prueba gratis de 7 días, el plan VIP y el uso de la app en Android.
        </p>

        <div class="contact-list">
          <a class="card contact-item" href={appConfig.whatsappUrl} target="_blank" rel="noopener">
            <strong>WhatsApp</strong>
            <span>{appConfig.whatsappNumber}</span>
          </a>

          <a class="card contact-item" href={appConfig.telegramUrl} target="_blank" rel="noopener">
            <strong>Telegram</strong>
            <span>{appConfig.telegramUser}</span>
          </a>

          <a class="card contact-item" href={appConfig.apkUrl} target="_blank" rel="noopener">
            <strong>Descarga</strong>
            <span>APK oficial para Android</span>
          </a>
        </div>
      </div>

      <div class="contact-card card">
        <img src={appConfig.image} alt="Imagen de TELELATINO" />

        <h2>Descarga TELELATINO</h2>

        <p>
          Accede a canales en vivo, eventos deportivos, películas y estrenos desde
          tu móvil Android. Empieza con {appConfig.trial.text}.
        </p>

        <div class="actions">
          <a href={appConfig.apkUrl} class="btn btn-primary" target="_blank" rel="noopener">
            Descargar APK
          </a>

          <a href={appConfig.whatsappUrl} class="btn btn-secondary" target="_blank" rel="noopener">
            Hablar por WhatsApp
          </a>
        </div>

        <p class="small-note">
          {appConfig.vipPlan.text}. Disponible solo para Android.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding: 90px 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 0.8fr;
    gap: 48px;
    align-items: start;
  }

  .contact-info h1 {
    margin: 22px 0 18px;
    font-size: clamp(2.5rem, 5vw, 4.4rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .contact-info p {
    max-width: 680px;
    color: var(--color-muted);
    font-size: 1.08rem;
  }

  .contact-list {
    display: grid;
    gap: 16px;
    margin-top: 32px;
  }

  .contact-item {
    display: block;
    padding: 20px;
  }

  .contact-item strong {
    display: block;
    margin-bottom: 6px;
    color: var(--color-primary);
  }

  .contact-item span {
    color: var(--color-muted);
  }

  .contact-card {
    padding: 34px;
    text-align: center;
  }

  .contact-card img {
    width: min(260px, 80%);
    border-radius: 34px;
    margin-bottom: 26px;
    box-shadow: 0 30px 90px rgba(255, 138, 0, 0.18);
  }

  .contact-card h2 {
    margin: 0 0 14px;
    font-size: 2rem;
  }

  .contact-card p {
    color: var(--color-muted);
    margin-bottom: 28px;
  }

  .actions {
    display: grid;
    gap: 14px;
  }

  .small-note {
    margin: 22px 0 0 !important;
    font-size: 0.9rem !important;
  }

  @media (max-width: 880px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>