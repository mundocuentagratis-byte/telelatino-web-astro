---
const pageTitle = "Vincular TV | Telelatino";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <main class="page">
      <section class="card">
        <div class="brand">
          <div class="logo">T</div>
          <div>
            <h1>Telelatino TV</h1>
            <p>Vincula tu Firestick, Android TV o TV Box</p>
          </div>
        </div>

        <div id="step-code" class="box">
          <h2>Vincular dispositivo</h2>
          <p class="muted">
            Ingresa el código que aparece en tu TV o escanea el QR desde la pantalla.
          </p>

          <label for="codeInput">Código de TV</label>
          <input id="codeInput" type="text" maxlength="10" placeholder="Ej: A7K92Q" />

          <button id="googleBtn" class="btn">
            Continuar con Google
          </button>

          <p id="message" class="message"></p>
        </div>

        <div id="loadingBox" class="box hidden">
          <div class="loader"></div>
          <h2>Procesando...</h2>
          <p>Estamos vinculando tu TV. No cierres esta página.</p>
        </div>

        <div id="successBox" class="box success hidden">
          <h2>TV vinculada correctamente</h2>
          <p>Ya puedes volver a la pantalla de tu TV. La app entrará automáticamente.</p>
        </div>

        <div id="errorBox" class="box error hidden">
          <h2>No se pudo vincular</h2>
          <p id="errorText">Intenta generar un nuevo código en la TV.</p>
        </div>
      </section>
    </main>

    <script type="module">
      import { initializeApp } from "firebase/app";
      import {
        getAuth,
        GoogleAuthProvider,
        signInWithPopup,
        signInWithRedirect,
        getRedirectResult
      } from "firebase/auth";

      const firebaseConfig = {
        apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY,
        authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
        projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
        appId: import.meta.env.PUBLIC_FIREBASE_APP_ID,
      };

      const API_BASE = import.meta.env.PUBLIC_TV_API_BASE || "https://telelatino-api.thiagobtav2.workers.dev";

      const app = initializeApp(firebaseConfig);
      const auth = getAuth(app);
      const provider = new GoogleAuthProvider();

      const codeInput = document.getElementById("codeInput");
      const googleBtn = document.getElementById("googleBtn");
      const message = document.getElementById("message");

      const stepCode = document.getElementById("step-code");
      const loadingBox = document.getElementById("loadingBox");
      const successBox = document.getElementById("successBox");
      const errorBox = document.getElementById("errorBox");
      const errorText = document.getElementById("errorText");

      const params = new URLSearchParams(window.location.search);
      const urlCode = (params.get("code") || "").trim().toUpperCase();

      if (urlCode) {
        codeInput.value = urlCode;
        localStorage.setItem("tv_login_code", urlCode);
      } else {
        const savedCode = localStorage.getItem("tv_login_code");
        if (savedCode) codeInput.value = savedCode;
      }

      function cleanCode(value) {
        return String(value || "")
          .trim()
          .toUpperCase()
          .replace(/[^A-Z0-9]/g, "");
      }

      codeInput.addEventListener("input", () => {
        codeInput.value = cleanCode(codeInput.value);
        if (codeInput.value) {
          localStorage.setItem("tv_login_code", codeInput.value);
        }
      });

      function showLoading() {
        stepCode.classList.add("hidden");
        successBox.classList.add("hidden");
        errorBox.classList.add("hidden");
        loadingBox.classList.remove("hidden");
      }

      function showSuccess() {
        loadingBox.classList.add("hidden");
        stepCode.classList.add("hidden");
        errorBox.classList.add("hidden");
        successBox.classList.remove("hidden");
        localStorage.removeItem("tv_login_code");
      }

      function showError(text) {
        loadingBox.classList.add("hidden");
        successBox.classList.add("hidden");
        stepCode.classList.add("hidden");
        errorBox.classList.remove("hidden");
        errorText.textContent = text || "No se pudo vincular esta TV.";
      }

      function showMessage(text, type = "") {
        message.textContent = text || "";
        message.className = "message " + type;
      }

      async function approveTvLogin(idToken, code) {
        const response = await fetch(`${API_BASE}/tv/login/approve`, {
          method: "POST",
          headers: {
            "Authorization": `Bearer ${idToken}`,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ code })
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok || !data.success) {
          throw new Error(data.message || "No se pudo vincular esta TV.");
        }

        return data;
      }

      async function handleApprovedUser(user) {
        const code = cleanCode(codeInput.value || localStorage.getItem("tv_login_code"));

        if (!code || code.length < 6) {
          showMessage("Ingresa el código que aparece en tu TV.", "bad");
          return;
        }

        localStorage.setItem("tv_login_code", code);

        showLoading();

        const idToken = await user.getIdToken(true);
        await approveTvLogin(idToken, code);

        showSuccess();
      }

      googleBtn.addEventListener("click", async () => {
        const code = cleanCode(codeInput.value);

        if (!code || code.length < 6) {
          showMessage("Primero ingresa el código de la TV.", "bad");
          return;
        }

        localStorage.setItem("tv_login_code", code);
        showMessage("");

        try {
          const result = await signInWithPopup(auth, provider);
          await handleApprovedUser(result.user);
        } catch (error) {
          try {
            await signInWithRedirect(auth, provider);
          } catch (redirectError) {
            showError(redirectError.message || error.message || "No se pudo iniciar sesión con Google.");
          }
        }
      });

      getRedirectResult(auth)
        .then(async (result) => {
          if (result && result.user) {
            await handleApprovedUser(result.user);
          }
        })
        .catch((error) => {
          showError(error.message || "No se pudo completar el inicio de sesión.");
        });
    </script>

    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background:
          radial-gradient(circle at top, rgba(255, 106, 0, 0.22), transparent 35%),
          linear-gradient(135deg, #05070d, #090f1f 55%, #03050a);
        color: #ffffff;
        min-height: 100vh;
      }

      .page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }

      .card {
        width: 100%;
        max-width: 460px;
        background: rgba(12, 18, 32, 0.92);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 28px;
        padding: 26px;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
      }

      .brand {
        display: flex;
        gap: 16px;
        align-items: center;
        margin-bottom: 28px;
      }

      .logo {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        background: linear-gradient(135deg, #ff7a00, #ff3300);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        font-weight: 900;
      }

      h1 {
        margin: 0;
        font-size: 28px;
      }

      .brand p {
        margin: 4px 0 0;
        color: #aab3c5;
        font-size: 14px;
      }

      .box {
        background: rgba(255, 255, 255, 0.045);
        border-radius: 22px;
        padding: 22px;
      }

      h2 {
        margin: 0 0 10px;
        font-size: 24px;
      }

      .muted {
        color: #aab3c5;
        line-height: 1.5;
        margin-bottom: 20px;
      }

      label {
        display: block;
        font-size: 14px;
        color: #c8d0df;
        margin-bottom: 8px;
      }

      input {
        width: 100%;
        height: 54px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.13);
        background: #090f1c;
        color: #ffffff;
        font-size: 24px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 3px;
        padding: 0 16px;
        outline: none;
      }

      input:focus {
        border-color: #ff7a00;
        box-shadow: 0 0 0 3px rgba(255, 122, 0, 0.18);
      }

      .btn {
        width: 100%;
        height: 54px;
        margin-top: 18px;
        border: none;
        border-radius: 16px;
        background: linear-gradient(135deg, #ff7a00, #ff3d00);
        color: #ffffff;
        font-size: 17px;
        font-weight: 800;
        cursor: pointer;
      }

      .btn:active {
        transform: scale(0.98);
      }

      .message {
        min-height: 22px;
        margin: 14px 0 0;
        color: #aab3c5;
        font-size: 14px;
      }

      .message.bad {
        color: #ff7676;
      }

      .hidden {
        display: none;
      }

      .success {
        border: 1px solid rgba(45, 212, 128, 0.35);
      }

      .success h2 {
        color: #4ade80;
      }

      .error {
        border: 1px solid rgba(248, 113, 113, 0.35);
      }

      .error h2 {
        color: #ff7676;
      }

      .loader {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        border: 4px solid rgba(255, 255, 255, 0.15);
        border-top-color: #ff7a00;
        animation: spin 0.8s linear infinite;
        margin-bottom: 18px;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      @media (max-width: 480px) {
        .card {
          padding: 20px;
          border-radius: 24px;
        }

        h1 {
          font-size: 23px;
        }

        h2 {
          font-size: 22px;
        }
      }
    </style>
  </body>
</html>
