---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog | TeleLatino Oficial"
  description="Guías, recomendaciones e información sobre entretenimiento digital, televisión online y contenido para usuarios."
>
  <section class="section page-hero">
    <div class="container">
      <span class="badge">Blog</span>
      <h1>Guías y artículos sobre entretenimiento digital.</h1>
      <p>
        Contenido útil para orientar a los usuarios, resolver dudas y fortalecer el
        posicionamiento orgánico del sitio.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container posts-grid">
      {
        posts.map((post) => (
          <article class="post-card card">
            <span>{post.data.category}</span>
            <h2>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h2>
            <p>{post.data.description}</p>
            <small>
              {post.data.pubDate.toLocaleDateString("es-ES", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </small>
            <a class="read-more" href={`/blog/${post.id}/`}>
              Leer artículo →
            </a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-bottom: 40px;
    text-align: center;
  }

  .page-hero h1 {
    max-width: 850px;
    margin: 22px auto 16px;
    font-size: clamp(2.4rem, 5vw, 4.4rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .page-hero p {
    max-width: 720px;
    margin: 0 auto;
    color: var(--color-muted);
    font-size: 1.08rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .post-card {
    padding: 28px;
  }

  .post-card span {
    display: inline-flex;
    margin-bottom: 16px;
    color: var(--color-primary);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
  }

  .post-card h2 {
    margin: 0 0 12px;
    font-size: 1.45rem;
    line-height: 1.15;
  }

  .post-card p {
    margin: 0 0 18px;
    color: var(--color-muted);
  }

  .post-card small {
    display: block;
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  .read-more {
    display: inline-flex;
    margin-top: 22px;
    color: var(--color-primary);
    font-weight: 800;
  }

  @media (max-width: 920px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>