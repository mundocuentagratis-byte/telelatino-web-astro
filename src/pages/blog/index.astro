---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const fallbackImage = "/images/telelatino-app.jpg";
---

<BaseLayout
  title="Blog | TELELATINO"
  description="Guías, estrenos, películas, entretenimiento digital y contenido útil para usuarios de TELELATINO."
>
  <section class="blog-hero">
    <div class="container">
      <span class="badge">Blog</span>

      <h1>Contenido útil para descubrir entretenimiento</h1>

      <p>
        Guías, películas, estrenos, recomendaciones y artículos pensados para
        usuarios que quieren disfrutar contenido digital desde Android.
      </p>
    </div>
  </section>

  <section class="blog-section">
    <div class="container">
      {
        sortedPosts.length > 0 ? (
          <div class="blog-grid">
            {sortedPosts.map((post) => (
              <article class="blog-card">
                <a href={`/blog/${post.id}/`} class="image-link">
                  <img
                    src={post.data.image || fallbackImage}
                    alt={post.data.imageAlt || post.data.title}
                    loading="lazy"
                  />
                </a>

                <div class="blog-card-content">
                  <span class="category">{post.data.category}</span>

                  <h2>
                    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                  </h2>

                  <p>{post.data.description}</p>

                  <div class="blog-meta">
                    <span>
                      {post.data.pubDate.toLocaleDateString("es-ES", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </span>
                  </div>

                  <a href={`/blog/${post.id}/`} class="read-more">
                    Leer artículo →
                  </a>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state card">
            <h2>Muy pronto habrá nuevos artículos</h2>
            <p>
              Estamos preparando contenido sobre películas, estrenos,
              entretenimiento digital y TELELATINO.
            </p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding: 90px 0 48px;
    text-align: center;
  }

  .blog-hero h1 {
    max-width: 900px;
    margin: 24px auto 18px;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.96;
    letter-spacing: -0.07em;
  }

  .blog-hero p {
    max-width: 760px;
    margin: 0 auto;
    color: var(--color-muted);
    font-size: 1.08rem;
  }

  .blog-section {
    padding: 30px 0 90px;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 26px;
  }

  .blog-card {
    overflow: hidden;
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.045)),
      rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.11);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.18);
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease;
  }

  .blog-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 198, 41, 0.32);
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.28);
  }

  .image-link {
    display: block;
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background:
      radial-gradient(circle at top left, rgba(255, 198, 41, 0.28), transparent 42%),
      rgba(255, 255, 255, 0.06);
  }

  .image-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.01);
    transition: transform 0.35s ease;
  }

  .blog-card:hover .image-link img {
    transform: scale(1.06);
  }

  .blog-card-content {
    padding: 24px;
  }

  .category {
    display: inline-flex;
    margin-bottom: 14px;
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blog-card h2 {
    margin: 0 0 12px;
    font-size: 1.45rem;
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .blog-card h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .blog-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.98rem;
  }

  .blog-meta {
    margin-top: 18px;
    color: var(--color-muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .read-more {
    display: inline-flex;
    margin-top: 20px;
    color: var(--color-primary);
    font-weight: 900;
    text-decoration: none;
  }

  .empty-state {
    max-width: 760px;
    margin: 0 auto;
    padding: 44px;
    text-align: center;
  }

  .empty-state h2 {
    margin: 0 0 12px;
    font-size: 2rem;
  }

  .empty-state p {
    margin: 0;
    color: var(--color-muted);
  }

  @media (max-width: 980px) {
    .blog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .blog-hero {
      padding-top: 70px;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-card-content {
      padding: 22px;
    }
  }
</style>