---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticlePage from "../../components/ArticlePage.astro";
import { appConfig } from "../../data/app";

export async function getStaticPaths() {
  const posts = await getCollection("noticias");

  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: {
        slug: post.id,
      },
      props: {
        post,
      },
    }));
}

type Props = {
  post: CollectionEntry<"noticias">;
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | ${appConfig.name}`} description={post.data.description}>
  <ArticlePage
    backHref="/noticias/"
    backLabel="← Ver todas las noticias"
    category={post.data.category || "Noticias"}
    title={post.data.title}
    description={post.data.description}
    pubDate={post.data.pubDate}
    image={post.data.image}
    imageAlt={post.data.imageAlt || post.data.title}
    youtubeVideoId={post.data.youtubeVideoId}
    youtubeVideoTitle={post.data.youtubeVideoTitle}
  >
    <Content />
  </ArticlePage>
</BaseLayout>